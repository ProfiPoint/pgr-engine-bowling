# ==============================================================================
# Visual Studio / VS Code / C++ / OpenGL Gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Compiled binaries and executables
# ------------------------------------------------------------------------------
*.com
*.class
*.dll
*.exe
*.o
*.so
*.obj
*.lib
*.a
*.out

# ------------------------------------------------------------------------------
# Visual Studio directories and files
# ------------------------------------------------------------------------------
.vs/
Debug/
Release/
x64/
x86/
[Bb]in/
[Oo]bj/
[Oo]ut/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.vcxproj.user

# ------------------------------------------------------------------------------
# VS Code
# ------------------------------------------------------------------------------
.vscode/

# (optional – pokud chceš sdílet settings, tak tohle smaž)
# !.vscode/settings.json
# !.vscode/tasks.json
# !.vscode/launch.json

# ------------------------------------------------------------------------------
# CMake
# ------------------------------------------------------------------------------
CMakeFiles/
CMakeCache.txt
cmake-build-*/
compile_commands.json
CTestTestfile.cmake
cmake_install.cmake
Makefile

# ------------------------------------------------------------------------------
# Intermediate / build / debug files
# ------------------------------------------------------------------------------
*.ilk
*.meta
*.pdb
*.tlog
*.idb
*.log
*.iobj
*.ipdb
*.aps
*.ncb
*.sdf
*.db
*.opendb
*.VC.db

# ------------------------------------------------------------------------------
# OS-specific
# ------------------------------------------------------------------------------
# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store

# Linux
*~

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
logs/
*.log

# ------------------------------------------------------------------------------
# Temporary files
# ------------------------------------------------------------------------------
tmp/
temp/